{
  "private": true,
  "name": "remnote-raindrop-plugin",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "check-types": "tsc",
    "test": "vitest run",
    "dev": "cross-env NODE_ENV=development webpack-dev-server --color --progress --no-open",
    "build": "npx remnote-plugin validate && shx rm -rf dist && cross-env NODE_ENV=production webpack --color --progress && cd dist && bestzip ../PluginZip.zip ./*"
  },
  "dependencies": {
    "@remnote/plugin-sdk": "^0.0.46",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@types/node": "^18.0.3",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "autoprefixer": "^10.4.7",
    "bestzip": "^2.2.1",
    "concurrently": "^7.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.7.1",
    "esbuild-loader": "^4.5.0",
    "glob": "^10.5.0",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.6.1",
    "postcss": "^8.4.14",
    "postcss-import": "^14.1.0",
    "postcss-loader": "^7.0.0",
    "react-refresh": "^0.14.0",
    "shx": "^0.3.4",
    "style-loader": "^3.3.1",
    "tailwindcss": "^3.1.5",
    "ts-node": "^10.9.1",
    "typescript": "^4.7.4",
    "vitest": "^3.2.7",
    "webpack": "^5.73.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.6"
  },
  "overrides": {
    "sockjs": {
      "uuid": "^11.1.1"
    }
  }
